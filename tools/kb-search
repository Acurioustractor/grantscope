#!/usr/bin/env python3
"""
kb-search — Fast BM25 full-text search over your Obsidian/kb vault

Builds and maintains a SQLite search index over all wiki/ and raw/ markdown
files. Called by `kb query` to find relevant articles before loading them into
the LLM context window.

Usage (standalone):
    kb-search "mutual aid funding models"          → top-10 matches
    kb-search "CORENA revolving fund" --top=5      → top-5 with excerpts
    kb-search "indigenous corporations" --json     → JSON output for piping
    kb-search --reindex                            → rebuild full index
    kb-search --stats                              → index statistics

Used internally by kb query via:
    kb-search "<query>" --json --top=15
"""

import argparse
import json
import math
import os
import re
import sqlite3
import sys
from collections import Counter
from pathlib import Path

# ─── Config ───────────────────────────────────────────────────────────────────

INDEX_FILE = ".kb-search.db"          # lives in vault root, gitignored
MIN_WORD_LEN = 2
MAX_EXCERPT_CHARS = 300
BM25_K1 = 1.5                         # term frequency saturation
BM25_B  = 0.75                        # length normalisation

# Words to ignore in indexing and queries
STOPWORDS = {
    'a','an','and','are','as','at','be','by','for','from','has','he','in',
    'is','it','its','of','on','that','the','to','was','were','will','with',
    'this','but','or','not','they','their','have','had','been','which',
    'who','what','when','where','how','all','also','can','do','did',
    'if','no','so','up','out','about','into','then','than','more',
    'we','our','you','your','i','my','she','her','him','his','they',
    'would','could','should','may','might','shall','there',
    # domain stopwords
    'australia','australian','org','organisation','organization',
}

# ─── Colors ───────────────────────────────────────────────────────────────────

class C:
    BOLD  = "\033[1m"
    DIM   = "\033[2m"
    GREEN = "\033[32m"
    BLUE  = "\033[34m"
    CYAN  = "\033[36m"
    YELLOW= "\033[33m"
    RED   = "\033[31m"
    RESET = "\033[0m"

# ─── Vault discovery ──────────────────────────────────────────────────────────

def find_vault_root() -> Path:
    p = Path.cwd()
    while p != p.parent:
        if (p / "AGENTS.md").exists():
            return p
        p = p.parent
    # Also try common locations relative to script
    script_parent = Path(__file__).parent.parent
    if (script_parent / "AGENTS.md").exists():
        return script_parent
    print(f"{C.RED}✗{C.RESET} Cannot find AGENTS.md — run from inside a kb vault", file=sys.stderr)
    sys.exit(1)

# ─── Tokeniser ────────────────────────────────────────────────────────────────

def tokenise(text: str) -> list[str]:
    """Lowercase, strip markdown, split on non-alpha, remove stopwords."""
    # Strip frontmatter
    text = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    # Strip markdown links, wikilinks, code blocks
    text = re.sub(r'```.*?```', ' ', text, flags=re.DOTALL)
    text = re.sub(r'`[^`]+`', ' ', text)
    text = re.sub(r'\[\[([^\]|]+)(?:\|[^\]]*)?\]\]', r'\1', text)  # wikilinks → text
    text = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', text)           # md links → text
    text = re.sub(r'[#*_~>|]', ' ', text)
    text = text.lower()
    words = re.findall(r'[a-z][a-z0-9\-]{1,}', text)
    return [w for w in words if w not in STOPWORDS and len(w) >= MIN_WORD_LEN]

def tokenise_query(query: str) -> list[str]:
    """Tokenise a user query, preserving quoted phrases as single tokens."""
    phrases = []
    # Extract quoted phrases first
    for phrase in re.findall(r'"([^"]+)"', query):
        phrases.append(phrase.lower().replace(' ', '_PHRASE_'))
        query = query.replace(f'"{phrase}"', '')
    tokens = tokenise(query)
    return tokens + phrases

# ─── BM25 implementation (pure stdlib) ────────────────────────────────────────

class BM25Index:
    """
    Okapi BM25 index stored in SQLite.
    Supports incremental updates — only reindexes changed files.
    """

    def __init__(self, db_path: Path):
        self.db_path = db_path
        self.conn = sqlite3.connect(str(db_path))
        self.conn.execute("PRAGMA journal_mode=WAL")
        self.conn.execute("PRAGMA synchronous=NORMAL")
        self._ensure_schema()

    def _ensure_schema(self):
        self.conn.executescript("""
            CREATE TABLE IF NOT EXISTS docs (
                id      INTEGER PRIMARY KEY,
                path    TEXT UNIQUE NOT NULL,
                title   TEXT,
                summary TEXT,
                mtime   REAL,
                length  INTEGER  -- token count
            );
            CREATE TABLE IF NOT EXISTS terms (
                doc_id  INTEGER NOT NULL REFERENCES docs(id) ON DELETE CASCADE,
                term    TEXT NOT NULL,
                freq    INTEGER NOT NULL,
                PRIMARY KEY (doc_id, term)
            );
            CREATE TABLE IF NOT EXISTS meta (
                key   TEXT PRIMARY KEY,
                value TEXT
            );
            CREATE INDEX IF NOT EXISTS idx_terms_term ON terms(term);
        """)
        self.conn.commit()

    # ── Indexing ──────────────────────────────────────────────────────────────

    def index_file(self, path: Path, vault_root: Path) -> bool:
        """Index or reindex a single file. Returns True if changed."""
        rel = str(path.relative_to(vault_root))
        mtime = path.stat().st_mtime
        row = self.conn.execute(
            "SELECT id, mtime FROM docs WHERE path = ?", (rel,)
        ).fetchone()

        if row and abs(row[1] - mtime) < 0.01:
            return False  # unchanged

        text = path.read_text(encoding='utf-8', errors='replace')
        tokens = tokenise(text)
        freq = Counter(tokens)

        # Extract title and summary from content
        title = extract_title(text, path)
        summary = extract_summary(text)

        if row:
            doc_id = row[0]
            self.conn.execute(
                "UPDATE docs SET mtime=?, length=?, title=?, summary=? WHERE id=?",
                (mtime, len(tokens), title, summary, doc_id)
            )
            self.conn.execute("DELETE FROM terms WHERE doc_id=?", (doc_id,))
        else:
            cur = self.conn.execute(
                "INSERT INTO docs (path, title, summary, mtime, length) VALUES (?,?,?,?,?)",
                (rel, title, summary, mtime, len(tokens))
            )
            doc_id = cur.lastrowid

        self.conn.executemany(
            "INSERT INTO terms (doc_id, term, freq) VALUES (?,?,?)",
            [(doc_id, term, count) for term, count in freq.items()]
        )
        return True

    def remove_deleted(self, existing_paths: set[str]):
        """Remove index entries for files that no longer exist."""
        indexed = {r[0] for r in self.conn.execute("SELECT path FROM docs")}
        stale = indexed - existing_paths
        for path in stale:
            self.conn.execute("DELETE FROM docs WHERE path=?", (path,))
        return len(stale)

    def commit(self):
        # Update corpus stats
        stats = self.conn.execute(
            "SELECT COUNT(*), AVG(length) FROM docs"
        ).fetchone()
        self.conn.execute(
            "INSERT OR REPLACE INTO meta VALUES ('doc_count', ?)", (str(stats[0]),)
        )
        self.conn.execute(
            "INSERT OR REPLACE INTO meta VALUES ('avg_length', ?)", (str(stats[1] or 0),)
        )
        self.conn.commit()

    # ── Searching ─────────────────────────────────────────────────────────────

    def search(self, query: str, top_k: int = 10, scope: str = 'all') -> list[dict]:
        """
        BM25 search. Returns ranked list of {path, title, summary, score, excerpt}.
        scope: 'all' | 'wiki' | 'raw'
        """
        tokens = tokenise_query(query)
        if not tokens:
            return []

        meta = dict(self.conn.execute("SELECT key, value FROM meta").fetchall())
        N = int(meta.get('doc_count', 1))
        avgdl = float(meta.get('avg_length', 100))

        if N == 0:
            return []

        # For each query term, get IDF and per-doc frequencies
        scores: dict[int, float] = {}
        matched_terms: dict[int, list[str]] = {}

        for term in set(tokens):
            # Phrase tokens — search for constituent words
            search_term = term.replace('_PHRASE_', ' ')
            if '_PHRASE_' in term:
                # Treat phrase as exact match bonus — score each word and multiply
                phrase_words = search_term.split()
                for pw in phrase_words:
                    self._score_term(pw, N, avgdl, scores, matched_terms, weight=2.0)
            else:
                # Also match stemmed variants (prefix match for longer terms)
                self._score_term(term, N, avgdl, scores, matched_terms, weight=1.0)
                if len(term) > 5:
                    self._score_prefix(term[:4], N, avgdl, scores, matched_terms, weight=0.6)

        if not scores:
            return []

        # Sort by score
        ranked = sorted(scores.items(), key=lambda x: x[1], reverse=True)[:top_k * 2]

        results = []
        for doc_id, score in ranked:
            row = self.conn.execute(
                "SELECT path, title, summary, length FROM docs WHERE id=?", (doc_id,)
            ).fetchone()
            if not row:
                continue

            path, title, summary, length = row

            # Filter by scope
            if scope == 'wiki' and not path.startswith('wiki/'):
                continue
            if scope == 'raw' and not path.startswith('raw/'):
                continue

            results.append({
                'path': path,
                'title': title or path,
                'summary': summary or '',
                'score': round(score, 3),
                'matched_terms': list(set(matched_terms.get(doc_id, []))),
            })

            if len(results) >= top_k:
                break

        return results

    def _score_term(self, term, N, avgdl, scores, matched_terms, weight=1.0):
        rows = self.conn.execute(
            "SELECT d.id, t.freq, d.length FROM terms t JOIN docs d ON t.doc_id=d.id WHERE t.term=?",
            (term,)
        ).fetchall()
        if not rows:
            return
        df = len(rows)
        idf = math.log((N - df + 0.5) / (df + 0.5) + 1)
        for doc_id, tf, dl in rows:
            norm_tf = (tf * (BM25_K1 + 1)) / (tf + BM25_K1 * (1 - BM25_B + BM25_B * dl / max(avgdl, 1)))
            scores[doc_id] = scores.get(doc_id, 0) + weight * idf * norm_tf
            matched_terms.setdefault(doc_id, []).append(term)

    def _score_prefix(self, prefix, N, avgdl, scores, matched_terms, weight=0.6):
        rows = self.conn.execute(
            "SELECT d.id, t.freq, d.length, t.term FROM terms t JOIN docs d ON t.doc_id=d.id WHERE t.term LIKE ?",
            (prefix + '%',)
        ).fetchall()
        if not rows:
            return
        # Group by term for IDF
        term_groups: dict[str, list] = {}
        for doc_id, tf, dl, term in rows:
            term_groups.setdefault(term, []).append((doc_id, tf, dl))
        for term, doc_rows in term_groups.items():
            df = len(doc_rows)
            idf = math.log((N - df + 0.5) / (df + 0.5) + 1)
            for doc_id, tf, dl in doc_rows:
                norm_tf = (tf * (BM25_K1 + 1)) / (tf + BM25_K1 * (1 - BM25_B + BM25_B * dl / max(avgdl, 1)))
                scores[doc_id] = scores.get(doc_id, 0) + weight * idf * norm_tf
                matched_terms.setdefault(doc_id, []).append(term)

    def stats(self) -> dict:
        meta = dict(self.conn.execute("SELECT key, value FROM meta").fetchall())
        term_count = self.conn.execute("SELECT COUNT(DISTINCT term) FROM terms").fetchone()[0]
        scope_counts = dict(self.conn.execute(
            "SELECT SUBSTR(path,1,4), COUNT(*) FROM docs GROUP BY SUBSTR(path,1,4)"
        ).fetchall())
        return {
            'documents': int(meta.get('doc_count', 0)),
            'unique_terms': term_count,
            'avg_doc_length': round(float(meta.get('avg_length', 0)), 1),
            'wiki_articles': scope_counts.get('wiki', 0),
            'raw_sources': scope_counts.get('raw/', 0),
            'index_size_kb': round(self.db_path.stat().st_size / 1024, 1) if self.db_path.exists() else 0,
        }

    def close(self):
        self.conn.close()

# ─── Text helpers ─────────────────────────────────────────────────────────────

def extract_title(text: str, path: Path) -> str:
    """Extract title from YAML frontmatter or first H1."""
    m = re.search(r'^---.*?title:\s*["\']?(.+?)["\']?\s*$.*?---', text, re.MULTILINE | re.DOTALL)
    if m:
        return m.group(1).strip()
    m = re.search(r'^#\s+(.+)$', text, re.MULTILINE)
    if m:
        return m.group(1).strip()
    return path.stem.replace('-', ' ').title()

def extract_summary(text: str) -> str:
    """Extract summary from frontmatter or first paragraph."""
    m = re.search(r'^---.*?summary:\s*["\']?(.+?)["\']?\s*$.*?---', text, re.MULTILINE | re.DOTALL)
    if m:
        return m.group(1).strip()[:200]
    # First non-heading, non-blank paragraph after frontmatter
    body = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    for line in body.split('\n'):
        line = line.strip()
        if line and not line.startswith('#') and not line.startswith('|') and not line.startswith('-'):
            return line[:200]
    return ''

def excerpt_with_highlights(vault_root: Path, result: dict, query_tokens: list[str]) -> str:
    """Find the best excerpt from the file containing query terms."""
    path = vault_root / result['path']
    if not path.exists():
        return result.get('summary', '')

    text = path.read_text(encoding='utf-8', errors='replace')
    # Strip frontmatter
    text = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    # Strip markdown formatting
    text = re.sub(r'```.*?```', '', text, flags=re.DOTALL)
    text = re.sub(r'[#*_~`]', '', text)
    text = re.sub(r'\[\[([^\]]+)\]\]', r'\1', text)
    text = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', text)
    text = ' '.join(text.split())

    if not text:
        return result.get('summary', '')

    # Find best window containing most query terms
    words = text.split()
    window = 60  # words
    best_score = -1
    best_start = 0

    for i in range(0, max(1, len(words) - window), 10):
        chunk = ' '.join(words[i:i+window]).lower()
        score = sum(1 for t in query_tokens if t in chunk)
        if score > best_score:
            best_score = score
            best_start = i

    excerpt = ' '.join(words[best_start:best_start + window])
    if len(excerpt) > MAX_EXCERPT_CHARS:
        excerpt = excerpt[:MAX_EXCERPT_CHARS] + '…'

    # Highlight matched terms (for terminal output)
    for term in query_tokens:
        if '_PHRASE_' not in term:
            excerpt = re.sub(
                rf'\b({re.escape(term)}[a-z]*)\b',
                f'{C.YELLOW}\\1{C.RESET}',
                excerpt,
                flags=re.IGNORECASE
            )
    return excerpt

# ─── Index management ─────────────────────────────────────────────────────────

def build_index(vault_root: Path, force: bool = False, quiet: bool = False) -> BM25Index:
    """Build or update the search index. Returns the index."""
    db_path = vault_root / INDEX_FILE
    idx = BM25Index(db_path)

    md_files = list((vault_root / 'wiki').rglob('*.md')) + \
               list((vault_root / 'raw').rglob('*.md'))
    md_files = [f for f in md_files if f.name != '.gitkeep']

    if force:
        idx.conn.execute("DELETE FROM docs")
        idx.conn.execute("DELETE FROM terms")
        idx.conn.commit()

    existing_paths = {str(f.relative_to(vault_root)) for f in md_files}
    removed = idx.remove_deleted(existing_paths)

    updated = 0
    for f in md_files:
        if idx.index_file(f, vault_root):
            updated += 1

    idx.commit()

    if not quiet:
        stats = idx.stats()
        if updated or removed:
            print(f"{C.GREEN}✓{C.RESET} Index updated: {stats['documents']} docs, {stats['unique_terms']:,} terms "
                  f"({updated} updated, {removed} removed)")
        else:
            print(f"{C.DIM}ℹ Index up-to-date: {stats['documents']} docs{C.RESET}")

    return idx

def ensure_index(vault_root: Path) -> BM25Index:
    """Auto-update the index if files have changed since last build."""
    db_path = vault_root / INDEX_FILE
    idx = BM25Index(db_path)

    # Quick check: any files newer than index?
    index_mtime = db_path.stat().st_mtime if db_path.exists() else 0
    md_files = list((vault_root / 'wiki').rglob('*.md')) + \
               list((vault_root / 'raw').rglob('*.md'))
    needs_update = any(f.stat().st_mtime > index_mtime for f in md_files)

    if needs_update:
        return build_index(vault_root, quiet=True)

    return idx

# ─── CLI ──────────────────────────────────────────────────────────────────────

def cmd_search(args):
    vault = find_vault_root()
    idx = ensure_index(vault)

    results = idx.search(args.query, top_k=args.top, scope=args.scope)
    idx.close()

    if not results:
        if args.json:
            print(json.dumps([]))
        else:
            print(f"{C.YELLOW}⚠{C.RESET} No results for: {args.query}")
        return

    if args.json:
        # JSON output for piping into kb query
        output = []
        for r in results:
            output.append({
                'path': r['path'],
                'title': r['title'],
                'summary': r['summary'],
                'score': r['score'],
                'matched_terms': r['matched_terms'],
            })
        print(json.dumps(output, indent=2))
        return

    # Human-readable output
    query_tokens = tokenise_query(args.query)
    print(f"\n{C.BOLD}Search results for:{C.RESET} {args.query}\n")
    for i, r in enumerate(results, 1):
        score_bar = '█' * min(10, int(r['score'] * 3)) + '░' * (10 - min(10, int(r['score'] * 3)))
        print(f"{C.BOLD}{i:2}. {r['title']}{C.RESET}")
        print(f"    {C.DIM}{r['path']}{C.RESET}  {C.CYAN}{score_bar}{C.RESET}  score={r['score']}")
        if r.get('matched_terms'):
            print(f"    {C.DIM}matched: {', '.join(r['matched_terms'][:8])}{C.RESET}")
        if args.excerpt or args.verbose:
            excerpt = excerpt_with_highlights(vault, r, query_tokens)
            if excerpt:
                wrapped = textwrap.fill(excerpt, width=80, initial_indent='    ', subsequent_indent='    ')
                print(f"{C.DIM}{wrapped}{C.RESET}")
        print()

def cmd_reindex(args):
    vault = find_vault_root()
    db_path = vault / INDEX_FILE
    if db_path.exists():
        db_path.unlink()
        print(f"{C.BLUE}ℹ{C.RESET} Cleared existing index")
    build_index(vault, force=False, quiet=False)

def cmd_stats(args):
    vault = find_vault_root()
    db_path = vault / INDEX_FILE
    if not db_path.exists():
        print(f"{C.YELLOW}⚠{C.RESET} No index found — run: kb-search --reindex")
        return
    idx = BM25Index(db_path)
    stats = idx.stats()
    idx.close()
    print(f"\n{C.BOLD}Search Index Stats{C.RESET}")
    print(f"  Documents:    {stats['documents']}")
    print(f"  Wiki articles:{stats['wiki_articles']}")
    print(f"  Raw sources:  {stats['raw_sources']}")
    print(f"  Unique terms: {stats['unique_terms']:,}")
    print(f"  Avg doc len:  {stats['avg_doc_length']} tokens")
    print(f"  Index size:   {stats['index_size_kb']} KB")
    print()

# ─── Main ─────────────────────────────────────────────────────────────────────

import textwrap

def main():
    parser = argparse.ArgumentParser(
        prog='kb-search',
        description='Fast BM25 search over your kb vault',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            examples:
              kb-search "mutual aid funding"
              kb-search "CORENA revolving fund" --top=5 --excerpt
              kb-search "foundation grants" --scope=wiki --json
              kb-search --reindex
              kb-search --stats
        """)
    )
    parser.add_argument('query', nargs='?', help='Search query')
    parser.add_argument('--top', type=int, default=10, help='Number of results (default 10)')
    parser.add_argument('--scope', choices=['all', 'wiki', 'raw'], default='all', help='Search scope')
    parser.add_argument('--json', action='store_true', help='Output JSON (for piping to kb query)')
    parser.add_argument('--excerpt', action='store_true', help='Show text excerpt with highlights')
    parser.add_argument('--verbose', '-v', action='store_true', help='Show excerpts for all results')
    parser.add_argument('--reindex', action='store_true', help='Rebuild the full search index')
    parser.add_argument('--stats', action='store_true', help='Show index statistics')

    args = parser.parse_args()

    if args.reindex:
        cmd_reindex(args)
    elif args.stats:
        cmd_stats(args)
    elif args.query:
        cmd_search(args)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
