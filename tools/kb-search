def find_vault_root() -> Path:
    p = Path.cwd()
    while p != p.parent:
        if (p / "AGENTS.md").exists():
            return p
        p = p.parent
    script_parent = Path(__file__).parent.parent
    if (script_parent / "AGENTS.md").exists():
        return script_parent
    err("Cannot find AGENTS.md — run from inside a kb vault")
    sys.exit(1)

# ─── Tokeniser ────────────────────────────────────────────────────────────────

def tokenise(text: str) -> list:
    text = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    text = re.sub(r'```.*?```', ' ', text, flags=re.DOTALL)
    text = re.sub(r'`[^`]+`', ' ', text)
    text = re.sub(r'\[\[([^\]|]+)(?:\|[^\]]*)?\]\]', r'\1', text)
    text = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', text)
    text = re.sub(r'[#*_~>|]', ' ', text)
    text = text.lower()
    words = re.findall(r'[a-z][a-z0-9\-]{1,}', text)
    return [w for w in words if w not in STOPWORDS and len(w) >= MIN_WORD_LEN]

def tokenise_query(query: str) -> list:
    phrases = []
    for phrase in re.findall(r'"([^"]+)"', query):
        phrases.append(phrase.lower().replace(' ', '_PHRASE_'))
        query = query.replace(f'"{phrase}"', '')
    return tokenise(query) + phrases

def text_for_embedding(text: str) -> str:
    """Strip markdown and return clean text for embedding."""
    text = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    text = re.sub(r'```.*?```', ' ', text, flags=re.DOTALL)
    text = re.sub(r'\[\[([^\]|]+)(?:\|[^\]]*)?\]\]', r'\1', text)
    text = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', text)
    text = re.sub(r'[#*_~`|>]', ' ', text)
    return re.sub(r'\s+', ' ', text).strip()[:2000]  # cap to avoid huge payloads

# ─── Vector helpers ───────────────────────────────────────────────────────────

def pack_vec(v: list) -> bytes:
    return struct.pack(f'{len(v)}f', *v)

def unpack_vec(b: bytes) -> list:
    n = len(b) // 4
    return list(struct.unpack(f'{n}f', b))

def dot(a: list, b: list) -> float:
    return sum(x * y for x, y in zip(a, b))

def norm(v: list) -> float:
    return math.sqrt(sum(x * x for x in v))

def cosine(a: list, b: list) -> float:
    na, nb = norm(a), norm(b)
    if na == 0 or nb == 0:
        return 0.0
    return max(-1.0, min(1.0, dot(a, b) / (na * nb)))

def normalize(v: list) -> list:
    n = norm(v)
    if n == 0:
        return v
    return [x / n for x in v]

# ─── Embedding: llama-server (/v1/embeddings) ─────────────────────────────────

def llm_embed_available() -> bool:
    try:
        r = urllib.request.urlopen(
            urllib.request.Request(f"{LLM_URL}/v1/models",
                                   headers={"Content-Type": "application/json"}),
            timeout=2
        )
        return r.status == 200
    except Exception:
        return False

def llm_embed(texts: list) -> list | None:
    """
    Call llama-server /v1/embeddings. Returns list of embedding vectors,
    or None if the server isn't running or doesn't support embeddings.
    """
    payload = json.dumps({
        "model": LLM_MODEL,
        "input": texts,
        "encoding_format": "float"
    }).encode()
    try:
        req = urllib.request.Request(
            EMBED_URL, data=payload,
            headers={"Content-Type": "application/json"}
        )
        with urllib.request.urlopen(req, timeout=60) as r:
            data = json.loads(r.read())
            # Sort by index to guarantee order
            items = sorted(data["data"], key=lambda x: x["index"])
            return [item["embedding"] for item in items]
    except (urllib.error.URLError, KeyError, json.JSONDecodeError):
        return None

# ─── Embedding: TF-IDF + SVD (LSA, numpy fallback) ────────────────────────────

class LSAEmbedder:
    """
    Latent Semantic Analysis — builds a TF-IDF matrix over the corpus,
    applies truncated SVD to get dense semantic vectors.
    Genuine semantic search: 'fund youth justice' → 'reinvestment programs'
    """

    def __init__(self, dim: int = EMBED_DIM_LSA):
        self.dim = dim
        self.vocab: dict = {}       # term → col index
        self.idf: list = []         # per-term IDF weights
        self.Vt: list | None = None # SVD right singular vectors (dim × vocab)
        self.fitted = False

    def fit(self, corpus: list):
        """
        corpus: list of (doc_id, token_list) tuples
        Builds vocabulary, IDF, and SVD projection matrix.
        """
        import numpy as np

        if not corpus:
            return

        # Build vocabulary from all docs
        all_terms = set()
        for _, tokens in corpus:
            all_terms.update(tokens)
        self.vocab = {t: i for i, t in enumerate(sorted(all_terms))}
        V = len(self.vocab)
        N = len(corpus)

        # Build TF-IDF matrix  (N × V)
        # TF = log(1 + freq/doc_len)
        # IDF = log(N / df + 1)
        df = [0] * V
        tf_matrix = []

        for _, tokens in corpus:
            freq = Counter(tokens)
            total = max(len(tokens), 1)
            row = [0.0] * V
            for term, count in freq.items():
                if term in self.vocab:
                    idx = self.vocab[term]
                    row[idx] = math.log1p(count / total)
                    df[idx] += 1
            tf_matrix.append(row)

        self.idf = [math.log((N + 1) / (d + 1)) + 1 for d in df]

        # Apply IDF weighting
        mat = np.array(tf_matrix, dtype=np.float32)
        idf_arr = np.array(self.idf, dtype=np.float32)
        mat *= idf_arr  # broadcast: each row × idf

        # L2 normalise rows
        row_norms = np.linalg.norm(mat, axis=1, keepdims=True)
        row_norms[row_norms == 0] = 1
        mat /= row_norms

        # Truncated SVD: mat ≈ U S Vt, keep top-dim components
        actual_dim = min(self.dim, min(mat.shape) - 1, 128)
        if actual_dim < 1:
            self.fitted = False
            return

        try:
            U, S, Vt = np.linalg.svd(mat, full_matrices=False)
            self.Vt = Vt[:actual_dim, :]   # (dim × V)
            self.dim = actual_dim
            self.fitted = True
        except Exception:
            self.fitted = False

    def embed(self, tokens: list) -> list | None:
        """Project a token list into LSA space."""
        if not self.fitted or self.Vt is None:
            return None
        import numpy as np

        V = len(self.vocab)
        vec = np.zeros(V, dtype=np.float32)
        freq = Counter(tokens)
        total = max(len(tokens), 1)
        for term, count in freq.items():
            if term in self.vocab:
                idx = self.vocab[term]
                vec[idx] = math.log1p(count / total) * self.idf[idx]
        n = np.linalg.norm(vec)
        if n > 0:
            vec /= n
        projected = self.Vt @ vec          # (dim,)
        result = projected.tolist()
        n2 = norm(result)
        if n2 > 0:
            result = [x / n2 for x in result]
        return result

