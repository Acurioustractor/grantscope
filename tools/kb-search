# ─── BM25 index ───────────────────────────────────────────────────────────────

class SearchIndex:
    def __init__(self, db_path: Path):
        self.db_path = db_path
        self.conn = sqlite3.connect(str(db_path))
        self.conn.execute("PRAGMA journal_mode=WAL")
        self.conn.execute("PRAGMA synchronous=NORMAL")
        self.conn.executescript(SCHEMA)
        self.conn.commit()
        self._lsa: LSAEmbedder | None = None

    # ── Indexing ──────────────────────────────────────────────────────────────

    def index_file(self, path: Path, vault_root: Path) -> bool:
        rel = str(path.relative_to(vault_root))
        mtime = path.stat().st_mtime
        row = self.conn.execute("SELECT id, mtime FROM docs WHERE path=?", (rel,)).fetchone()
        if row and abs(row[1] - mtime) < 0.01:
            return False

        text = path.read_text(encoding='utf-8', errors='replace')
        tokens = tokenise(text)
        freq = Counter(tokens)
        title = extract_title(text, path)
        summary = extract_summary(text)

        if row:
            doc_id = row[0]
            self.conn.execute(
                "UPDATE docs SET mtime=?,length=?,title=?,summary=? WHERE id=?",
                (mtime, len(tokens), title, summary, doc_id))
            self.conn.execute("DELETE FROM terms WHERE doc_id=?", (doc_id,))
            self.conn.execute("DELETE FROM embeddings WHERE doc_id=?", (doc_id,))
        else:
            cur = self.conn.execute(
                "INSERT INTO docs (path,title,summary,mtime,length) VALUES (?,?,?,?,?)",
                (rel, title, summary, mtime, len(tokens)))
            doc_id = cur.lastrowid

        self.conn.executemany(
            "INSERT INTO terms (doc_id,term,freq) VALUES (?,?,?)",
            [(doc_id, t, c) for t, c in freq.items()])
        return True

    def remove_deleted(self, existing: set) -> int:
        indexed = {r[0] for r in self.conn.execute("SELECT path FROM docs")}
        stale = indexed - existing
        for p in stale:
            self.conn.execute("DELETE FROM docs WHERE path=?", (p,))
        return len(stale)

    def commit_bm25(self):
        stats = self.conn.execute("SELECT COUNT(*), AVG(length) FROM docs").fetchone()
        self.conn.execute("INSERT OR REPLACE INTO meta VALUES ('doc_count',?)", (str(stats[0]),))
        self.conn.execute("INSERT OR REPLACE INTO meta VALUES ('avg_length',?)", (str(stats[1] or 0),))
        self.conn.commit()

    # ── Embedding: store ──────────────────────────────────────────────────────

    def store_embedding(self, doc_id: int, vector: list, source: str):
        blob = pack_vec(vector)
        self.conn.execute(
            "INSERT OR REPLACE INTO embeddings (doc_id,source,vector,dim) VALUES (?,?,?,?)",
            (doc_id, source, blob, len(vector)))

    def get_embedding(self, doc_id: int) -> tuple | None:
        row = self.conn.execute(
            "SELECT vector, source FROM embeddings WHERE doc_id=?", (doc_id,)).fetchone()
        if row:
            return unpack_vec(row[0]), row[1]
        return None

    def all_docs_without_embeddings(self, source: str | None = None) -> list:
        if source:
            return self.conn.execute(
                "SELECT d.id, d.path FROM docs d "
                "LEFT JOIN embeddings e ON d.id=e.doc_id "
                "WHERE e.doc_id IS NULL OR e.source != ?", (source,)
            ).fetchall()
        return self.conn.execute(
            "SELECT d.id, d.path FROM docs d "
            "LEFT JOIN embeddings e ON d.id=e.doc_id WHERE e.doc_id IS NULL"
        ).fetchall()

    def all_doc_embeddings(self, source: str | None = None) -> list:
        """Return [(doc_id, vector)] for all embedded docs."""
        if source:
            rows = self.conn.execute(
                "SELECT doc_id, vector FROM embeddings WHERE source=?", (source,)).fetchall()
        else:
            rows = self.conn.execute("SELECT doc_id, vector FROM embeddings").fetchall()
        return [(r[0], unpack_vec(r[1])) for r in rows]

    # ── LSA model persistence ─────────────────────────────────────────────────

    def save_lsa_model(self, lsa: LSAEmbedder):
        import pickle
        blob = pickle.dumps({
            'vocab': lsa.vocab,
            'idf': lsa.idf,
            'Vt': lsa.Vt,
            'dim': lsa.dim,
            'fitted': lsa.fitted,
        })
        self.conn.execute(
            "INSERT OR REPLACE INTO lsa_model VALUES ('model', ?)", (blob,))
        self.conn.commit()

    def load_lsa_model(self) -> LSAEmbedder | None:
        import pickle
        row = self.conn.execute("SELECT value FROM lsa_model WHERE key='model'").fetchone()
        if not row:
            return None
        try:
            data = pickle.loads(row[0])
            lsa = LSAEmbedder(data['dim'])
            lsa.vocab = data['vocab']
            lsa.idf = data['idf']
            lsa.Vt = data['Vt']
            lsa.dim = data['dim']
            lsa.fitted = data['fitted']
            return lsa
        except Exception:
            return None

    # ── BM25 search ───────────────────────────────────────────────────────────

    def bm25_search(self, query: str, top_k: int = 30, scope: str = 'all') -> dict:
        """Returns {doc_id: bm25_score}"""
        tokens = tokenise_query(query)
        if not tokens:
            return {}

        meta = dict(self.conn.execute("SELECT key,value FROM meta").fetchall())
        N = int(meta.get('doc_count', 1))
        avgdl = float(meta.get('avg_length', 100))
        if N == 0:
            return {}

        scores = {}
        for term in set(tokens):
            weight = 2.0 if '_PHRASE_' in term else 1.0
            t = term.replace('_PHRASE_', ' ')
            self._bm25_term(t, N, avgdl, scores, weight)
            if len(t) > 5:
                self._bm25_prefix(t[:4], N, avgdl, scores, 0.5)

        if scope != 'all':
            prefix = 'wiki/' if scope == 'wiki' else 'raw/'
            paths = {r[0]: r[1] for r in self.conn.execute("SELECT id, path FROM docs")}
            scores = {k: v for k, v in scores.items()
                      if paths.get(k, '').startswith(prefix)}

        return scores

    def _bm25_term(self, term, N, avgdl, scores, weight=1.0):
        rows = self.conn.execute(
            "SELECT d.id, t.freq, d.length FROM terms t JOIN docs d ON t.doc_id=d.id WHERE t.term=?",
            (term,)).fetchall()
        if not rows:
            return
        df = len(rows)
        idf = math.log((N - df + 0.5) / (df + 0.5) + 1)
        for doc_id, tf, dl in rows:
            ntf = (tf * (BM25_K1 + 1)) / (tf + BM25_K1 * (1 - BM25_B + BM25_B * dl / max(avgdl,1)))
            scores[doc_id] = scores.get(doc_id, 0) + weight * idf * ntf

    def _bm25_prefix(self, prefix, N, avgdl, scores, weight=0.5):
        rows = self.conn.execute(
            "SELECT d.id, t.freq, d.length, t.term FROM terms t JOIN docs d ON t.doc_id=d.id WHERE t.term LIKE ?",
            (prefix + '%',)).fetchall()
        by_term = {}
        for doc_id, tf, dl, term in rows:
            by_term.setdefault(term, []).append((doc_id, tf, dl))
        for term, doc_rows in by_term.items():
            df = len(doc_rows)
            idf = math.log((N - df + 0.5) / (df + 0.5) + 1)
            for doc_id, tf, dl in doc_rows:
                ntf = (tf * (BM25_K1+1)) / (tf + BM25_K1*(1-BM25_B+BM25_B*dl/max(avgdl,1)))
                scores[doc_id] = scores.get(doc_id, 0) + weight * idf * ntf

    # ── Semantic search ───────────────────────────────────────────────────────

    def semantic_search(self, query: str, top_k: int = 30,
                        scope: str = 'all', lsa: LSAEmbedder | None = None) -> dict:
        """
        Returns {doc_id: cosine_similarity}.
        Uses LLM embeddings if server available, else LSA.
        """
        # Try LLM embeddings first
        if llm_embed_available():
            q_vecs = llm_embed([query])
            if q_vecs:
                q_vec = normalize(q_vecs[0])
                # Look for LLM-embedded docs
                doc_embeds = self.all_doc_embeddings(source='llm')
                if doc_embeds:
                    return self._cosine_rank(q_vec, doc_embeds, scope, top_k)

        # Fallback to LSA
        if lsa and lsa.fitted:
            q_tokens = tokenise(query)
            q_vec = lsa.embed(q_tokens)
            if q_vec:
                doc_embeds = self.all_doc_embeddings(source='lsa')
                if doc_embeds:
                    return self._cosine_rank(q_vec, doc_embeds, scope, top_k)

        return {}

    def _cosine_rank(self, q_vec, doc_embeds, scope, top_k) -> dict:
        """Compute cosine scores, optionally filtered by scope."""
        if scope != 'all':
            prefix = 'wiki/' if scope == 'wiki' else 'raw/'
            paths = {r[0]: r[1] for r in self.conn.execute("SELECT id, path FROM docs")}
        scores = {}
        for doc_id, d_vec in doc_embeds:
            if scope != 'all' and not paths.get(doc_id, '').startswith(prefix):
                continue
            scores[doc_id] = cosine(q_vec, d_vec)
        return scores

    # ── Hybrid merge ──────────────────────────────────────────────────────────

    def hybrid_search(self, query: str, top_k: int = 10,
                      scope: str = 'all', alpha: float = HYBRID_ALPHA,
                      lsa: LSAEmbedder | None = None) -> list:
        """
        Merge BM25 + semantic scores using Reciprocal Rank Fusion + linear blend.
        Returns ranked list of {path, title, summary, score, bm25, semantic, matched_terms}.
        """
        bm25_scores  = self.bm25_search(query, top_k=top_k*3, scope=scope)
        sem_scores   = self.semantic_search(query, top_k=top_k*3, scope=scope, lsa=lsa)

        has_semantic = bool(sem_scores)

        # Normalise both score dicts to [0,1]
        def normalise(d: dict) -> dict:
            if not d:
                return {}
            lo, hi = min(d.values()), max(d.values())
            if hi == lo:
                return {k: 1.0 for k in d}
            return {k: (v - lo) / (hi - lo) for k, v in d.items()}

        bm25_n = normalise(bm25_scores)
        sem_n  = normalise(sem_scores)

        # Union of all doc_ids
        all_ids = set(bm25_n) | set(sem_n)

        # Effective alpha: if no semantic scores, use BM25 only
        eff_alpha = alpha if has_semantic else 0.0

        combined = {}
        for doc_id in all_ids:
            b = bm25_n.get(doc_id, 0.0)
            s = sem_n.get(doc_id, 0.0)
            combined[doc_id] = (1 - eff_alpha) * b + eff_alpha * s

        ranked = sorted(combined.items(), key=lambda x: x[1], reverse=True)[:top_k*2]

        results = []
        for doc_id, score in ranked:
            row = self.conn.execute(
                "SELECT path, title, summary FROM docs WHERE id=?", (doc_id,)).fetchone()
            if not row:
                continue
            path, title, summary = row

            # Get matched terms for display
            q_tokens = tokenise_query(query)
            matched = [t for t in q_tokens
                       if self.conn.execute(
                           "SELECT 1 FROM terms WHERE doc_id=? AND term=?",
                           (doc_id, t)).fetchone()]

            results.append({
                'path': path,
                'title': title or path,
                'summary': summary or '',
                'score': round(score, 4),
                'bm25': round(bm25_n.get(doc_id, 0.0), 4),
                'semantic': round(sem_n.get(doc_id, 0.0), 4),
                'semantic_source': 'llm' if (has_semantic and doc_id in sem_scores) else 'lsa',
                'matched_terms': matched,
            })
            if len(results) >= top_k:
                break

        return results

    def stats(self) -> dict:
        meta = dict(self.conn.execute("SELECT key,value FROM meta").fetchall())
        term_count = self.conn.execute("SELECT COUNT(DISTINCT term) FROM terms").fetchone()[0]
        embed_counts = dict(self.conn.execute(
            "SELECT source, COUNT(*) FROM embeddings GROUP BY source").fetchall())
        scope_counts = dict(self.conn.execute(
            "SELECT SUBSTR(path,1,4), COUNT(*) FROM docs GROUP BY SUBSTR(path,1,4)").fetchall())
        return {
            'documents': int(meta.get('doc_count', 0)),
            'unique_terms': term_count,
            'avg_doc_length': round(float(meta.get('avg_length', 0)), 1),
            'wiki_articles': scope_counts.get('wiki', 0),
            'raw_sources': scope_counts.get('raw/', 0),
            'llm_embeddings': embed_counts.get('llm', 0),
            'lsa_embeddings': embed_counts.get('lsa', 0),
            'index_size_kb': round(self.db_path.stat().st_size / 1024, 1)
                             if self.db_path.exists() else 0,
        }

    def close(self):
        self.conn.close()

# ─── Text helpers ─────────────────────────────────────────────────────────────

def extract_title(text, path):
    m = re.search(r'^---.*?title:\s*["\']?(.+?)["\']?\s*$.*?---', text, re.MULTILINE|re.DOTALL)
    if m: return m.group(1).strip()
    m = re.search(r'^#\s+(.+)$', text, re.MULTILINE)
    if m: return m.group(1).strip()
    return path.stem.replace('-', ' ').title()

def extract_summary(text):
    m = re.search(r'^---.*?summary:\s*["\']?(.+?)["\']?\s*$.*?---', text, re.MULTILINE|re.DOTALL)
    if m: return m.group(1).strip()[:200]
    body = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    for line in body.split('\n'):
        line = line.strip()
        if line and not line.startswith('#') and not line.startswith('|') and not line.startswith('-'):
            return line[:200]
    return ''

def excerpt_with_highlights(vault_root, result, query_tokens):
    path = vault_root / result['path']
    if not path.exists():
        return result.get('summary', '')
    text = path.read_text(encoding='utf-8', errors='replace')
    text = re.sub(r'^---.*?---\s*', '', text, flags=re.DOTALL)
    text = re.sub(r'```.*?```', '', text, flags=re.DOTALL)
    text = re.sub(r'[#*_~`|]', '', text)
    text = re.sub(r'\[\[([^\]]+)\]\]', r'\1', text)
    text = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', text)
    text = ' '.join(text.split())
    if not text:
        return result.get('summary', '')
    words = text.split()
    window = 60
    best_score, best_start = -1, 0
    for i in range(0, max(1, len(words) - window), 10):
        chunk = ' '.join(words[i:i+window]).lower()
        score = sum(1 for t in query_tokens if t in chunk)
        if score > best_score:
            best_score, best_start = score, i
    excerpt = ' '.join(words[best_start:best_start + window])
    if len(excerpt) > MAX_EXCERPT_CHARS:
        excerpt = excerpt[:MAX_EXCERPT_CHARS] + '…'
    for term in query_tokens:
        if '_PHRASE_' not in term:
            excerpt = re.sub(
                rf'\b({re.escape(term)}[a-z]*)\b',
                f'{C.YELLOW}\\1{C.RESET}', excerpt, flags=re.IGNORECASE)
    return excerpt

# ─── Index build ──────────────────────────────────────────────────────────────

def get_md_files(vault_root: Path) -> list:
    files = []
    for d in ['wiki', 'raw']:
        p = vault_root / d
        if p.exists():
            files.extend(f for f in p.rglob('*.md') if f.name != '.gitkeep')
    return files

def build_index(vault_root: Path, embed: bool = False,
                force: bool = False, quiet: bool = False) -> SearchIndex:
    db_path = vault_root / INDEX_FILE
    idx = SearchIndex(db_path)

    md_files = get_md_files(vault_root)
    if force:
        idx.conn.execute("DELETE FROM docs")
        idx.conn.execute("DELETE FROM terms")
        idx.conn.execute("DELETE FROM embeddings")
        idx.conn.execute("DELETE FROM lsa_model")
        idx.conn.commit()

    existing = {str(f.relative_to(vault_root)) for f in md_files}
    removed = idx.remove_deleted(existing)
    updated = sum(1 for f in md_files if idx.index_file(f, vault_root))
    idx.commit_bm25()

    # Build/update embeddings
    embed_source = 'pending'
    if embed or updated > 0:
        embed_source = _build_embeddings(idx, vault_root, md_files, quiet)

    if not quiet:
        s = idx.stats()
        mode = f"llm({s['llm_embeddings']})+lsa({s['lsa_embeddings']})" \
               if (s['llm_embeddings'] or s['lsa_embeddings']) else "bm25-only"
        print(f"{C.GREEN}✓{C.RESET} Index: {s['documents']} docs, "
              f"{s['unique_terms']:,} terms, {mode} "
              f"({updated} updated, {removed} removed)")
    return idx

def _build_embeddings(idx: SearchIndex, vault_root: Path,
                      md_files: list, quiet: bool) -> str:
    """Build LSA model over all docs, then try LLM embeddings for changed docs."""

    # Always build/rebuild LSA over all docs (fast, offline)
    if not quiet:
        info("Building LSA semantic model...")

    corpus = []
    for f in md_files:
        rel = str(f.relative_to(vault_root))
        row = idx.conn.execute("SELECT id FROM docs WHERE path=?", (rel,)).fetchone()
        if not row:
            continue
        text = f.read_text(encoding='utf-8', errors='replace')
        corpus.append((row[0], tokenise(text)))

    lsa = LSAEmbedder(EMBED_DIM_LSA)
    lsa.fit(corpus)

    if lsa.fitted:
        # Store LSA embeddings for every doc
        for doc_id, tokens in corpus:
            vec = lsa.embed(tokens)
            if vec:
                idx.store_embedding(doc_id, vec, 'lsa')
        idx.save_lsa_model(lsa)
        if not quiet:
            ok(f"LSA model fitted ({lsa.dim} dimensions, {len(lsa.vocab):,} terms)")

    # Try LLM embeddings (overrides LSA where available)
    if llm_embed_available():
        if not quiet:
            info("LLM server detected — computing neural embeddings...")
        docs_to_embed = [(doc_id, path)
                         for doc_id, path in idx.conn.execute("SELECT id, path FROM docs")]
        _embed_with_llm(idx, vault_root, docs_to_embed, quiet)
        return 'llm+lsa'
    else:
        if not quiet and lsa.fitted:
            info("LLM server not detected — using LSA semantic search")
            info("Start llama-server with --embeddings for neural embeddings")
        return 'lsa'

def _embed_with_llm(idx: SearchIndex, vault_root: Path,
                    docs: list, quiet: bool):
    """Batch-embed docs using llama-server."""
    batches = [docs[i:i+EMBED_BATCH_SIZE] for i in range(0, len(docs), EMBED_BATCH_SIZE)]
    total = 0
    for batch in batches:
        texts = []
        for doc_id, rel_path in batch:
            fpath = vault_root / rel_path
            if fpath.exists():
                text = text_for_embedding(fpath.read_text(encoding='utf-8', errors='replace'))
                texts.append(text)
            else:
                texts.append('')
        vecs = llm_embed(texts)
        if vecs:
            for (doc_id, _), vec in zip(batch, vecs):
                idx.store_embedding(doc_id, normalize(vec), 'llm')
            total += len(batch)
    idx.conn.commit()
    if not quiet and total:
        ok(f"LLM embeddings computed for {total} docs")

def ensure_index(vault_root: Path, quiet: bool = True) -> tuple:
    """Return (SearchIndex, LSAEmbedder|None), auto-updating if files changed."""
    db_path = vault_root / INDEX_FILE
    index_mtime = db_path.stat().st_mtime if db_path.exists() else 0
    md_files = get_md_files(vault_root)
    needs_update = any(f.stat().st_mtime > index_mtime for f in md_files)
    if needs_update or not db_path.exists():
        idx = build_index(vault_root, embed=True, quiet=quiet)
    else:
        idx = SearchIndex(db_path)
    lsa = idx.load_lsa_model()
    return idx, lsa

# ─── CLI commands ─────────────────────────────────────────────────────────────

def cmd_search(args):
    vault = find_vault_root()
    idx, lsa = ensure_index(vault)

    # Choose search mode
    if args.bm25:
        raw = idx.bm25_search(args.query, top_k=args.top, scope=args.scope)
        results = []
        for doc_id, score in sorted(raw.items(), key=lambda x: x[1], reverse=True)[:args.top]:
            row = idx.conn.execute("SELECT path,title,summary FROM docs WHERE id=?", (doc_id,)).fetchone()
            if row:
                results.append({'path':row[0],'title':row[1] or row[0],
                                 'summary':row[2] or '','score':round(score,4),
                                 'bm25':round(score,4),'semantic':0.0,
                                 'semantic_source':'none','matched_terms':[]})
    elif args.semantic:
        raw = idx.semantic_search(args.query, top_k=args.top, scope=args.scope, lsa=lsa)
        results = []
        for doc_id, score in sorted(raw.items(), key=lambda x: x[1], reverse=True)[:args.top]:
            row = idx.conn.execute("SELECT path,title,summary FROM docs WHERE id=?", (doc_id,)).fetchone()
            if row:
                results.append({'path':row[0],'title':row[1] or row[0],
                                 'summary':row[2] or '','score':round(score,4),
                                 'bm25':0.0,'semantic':round(score,4),
                                 'semantic_source':'lsa','matched_terms':[]})
    else:
        results = idx.hybrid_search(args.query, top_k=args.top, scope=args.scope, lsa=lsa)

    idx.close()

    if not results:
        if args.json:
            print(json.dumps([]))
        else:
            print(f"{C.YELLOW}⚠{C.RESET} No results for: {args.query}")
        return

    if args.json:
        print(json.dumps(results, indent=2))
        return

    # Human output
    q_tokens = tokenise_query(args.query)
    sem_available = any(r.get('semantic', 0) > 0 for r in results)
    mode_str = f"hybrid (bm25 + {'llm' if llm_embed_available() else 'lsa'} semantic)" \
               if sem_available else "bm25 only"
    print(f"\n{C.BOLD}Results for:{C.RESET} {args.query}  {C.DIM}[{mode_str}]{C.RESET}\n")

    for i, r in enumerate(results, 1):
        # Score bar: split into BM25 (blue) and semantic (cyan) portions
        b_fill = int(r.get('bm25', 0) * 5)
        s_fill = int(r.get('semantic', 0) * 5)
        bar = C.BLUE + '█' * b_fill + C.CYAN + '█' * s_fill + \
              C.DIM + '░' * max(0, 10 - b_fill - s_fill) + C.RESET

        src = r.get('semantic_source', '')
        src_tag = f" {C.DIM}[{src}]{C.RESET}" if src and src != 'none' else ''

        print(f"{C.BOLD}{i:2}. {r['title']}{C.RESET}")
        print(f"    {C.DIM}{r['path']}{C.RESET}  {bar}  "
              f"score={r['score']:.3f} bm25={r.get('bm25',0):.2f} "
              f"sem={r.get('semantic',0):.2f}{src_tag}")
        if r.get('matched_terms'):
            print(f"    {C.DIM}keywords: {', '.join(r['matched_terms'][:8])}{C.RESET}")
        if args.excerpt or args.verbose:
            exc = excerpt_with_highlights(vault, r, q_tokens)
            if exc:
                wrapped = textwrap.fill(exc, 80, initial_indent='    ', subsequent_indent='    ')
                print(f"{C.DIM}{wrapped}{C.RESET}")
        print()


def cmd_reindex(args):
    vault = find_vault_root()
    db_path = vault / INDEX_FILE
    if db_path.exists():
        db_path.unlink()
        print(f"{C.BLUE}ℹ{C.RESET} Cleared index")
    build_index(vault, embed=True, force=False, quiet=False)


def cmd_stats(args):
    vault = find_vault_root()
    db_path = vault / INDEX_FILE
    if not db_path.exists():
        warn("No index — run: kb-search --reindex")
        return
    idx = SearchIndex(db_path)
    s = idx.stats()
    lsa = idx.load_lsa_model()
    idx.close()

    llm_up = llm_embed_available()
    print(f"\n{C.BOLD}kb-search Index{C.RESET}")
    print(f"  Documents:       {s['documents']}")
    print(f"  Wiki articles:   {s['wiki_articles']}")
    print(f"  Raw sources:     {s['raw_sources']}")
    print(f"  Unique terms:    {s['unique_terms']:,}")
    print(f"  Avg doc length:  {s['avg_doc_length']} tokens")
    print(f"  Index size:      {s['index_size_kb']} KB")
    print(f"\n  {C.BOLD}Semantic search:{C.RESET}")
    print(f"  LLM server:      {'🟢 running' if llm_up else '🔴 offline'}")
    print(f"  LLM embeddings:  {s['llm_embeddings']} docs")
    print(f"  LSA embeddings:  {s['lsa_embeddings']} docs"
          + (f" ({lsa.dim}d)" if lsa else ""))
    if lsa and lsa.fitted:
        print(f"  LSA vocab:       {len(lsa.vocab):,} terms")
    print()


# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog='kb-search',
        description='Hybrid semantic + BM25 search over your kb vault',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            examples:
              kb-search "who funds youth justice"
              kb-search "CORENA revolving fund" --excerpt
              kb-search "foundation grants" --semantic
              kb-search "grant dependency" --bm25
              kb-search "indigenous self-determination" --scope=wiki -v
              kb-search --reindex --embed
              kb-search --stats
        """)
    )
    parser.add_argument('query', nargs='?', help='Search query')
    parser.add_argument('--top',      type=int, default=10)
    parser.add_argument('--scope',    choices=['all','wiki','raw'], default='all')
    parser.add_argument('--json',     action='store_true', help='JSON output')
    parser.add_argument('--excerpt',  action='store_true', help='Show excerpt')
    parser.add_argument('--verbose','-v', action='store_true')
    parser.add_argument('--bm25',    action='store_true', help='BM25 only')
    parser.add_argument('--semantic', action='store_true', help='Semantic only')
    parser.add_argument('--reindex', action='store_true')
    parser.add_argument('--embed',   action='store_true', help='Force recompute embeddings')
    parser.add_argument('--stats',   action='store_true')

    args = parser.parse_args()

    if args.reindex:
        cmd_reindex(args)
    elif args.stats:
        cmd_stats(args)
    elif args.query:
        cmd_search(args)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
