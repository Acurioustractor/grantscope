def cmd_log(args):
    """Show recent knowledge base activity from log.md."""
    vault = find_vault_root()
    log_path = vault / LOG_FILE

    if not log_path.exists():
        warn("No log yet — run some kb commands first.")
        return

    content = log_path.read_text(encoding="utf-8", errors="replace")
    entries = re.split(r'(?=^## \[)', content, flags=re.MULTILINE)
    entries = [e for e in entries if e.strip().startswith("## [")]

    # Filter if --grep provided
    if args.grep:
        entries = [e for e in entries if args.grep.lower() in e.lower()]

    # Take tail
    entries = entries[-args.tail:]

    if not entries:
        warn(f"No log entries{f' matching \"{args.grep}\"' if args.grep else ''}.")
        return

    # Colour-code by operation type
    op_colours = {
        "ingest":  C.GREEN,
        "compile": C.BLUE,
        "query":   C.CYAN,
        "filed":   C.YELLOW,
        "lint":    C.DIM,
        "output":  C.DIM,
    }

    print(f"\n{C.BOLD}Knowledge Base Log{C.RESET}  "
          f"{C.DIM}({len(entries)} entries{f', filtered: \"{args.grep}\"' if args.grep else ''}){C.RESET}\n")

    for entry in entries:
        # Colour the operation keyword
        for op, colour in op_colours.items():
            entry = re.sub(
                rf'(## \[.+?\] )({op})',
                rf'\1{colour}{op}{C.RESET}',
                entry, count=1
            )
        print(entry.rstrip())
        print()

    # Quick stats
    all_entries = re.split(r'(?=^## \[)', content, flags=re.MULTILINE)
    all_entries = [e for e in all_entries if e.strip().startswith("## [")]
    ops = {}
    for e in all_entries:
        m = re.search(r'^## \[.+?\] (\w+)', e, re.MULTILINE)
        if m:
            ops[m.group(1)] = ops.get(m.group(1), 0) + 1
    stats_str = "  ".join(f"{op}: {count}" for op, count in sorted(ops.items()))
    print(f"{C.DIM}Total: {len(all_entries)} entries — {stats_str}{C.RESET}\n")


def cmd_search_wrapper(args):
    """Thin wrapper: delegate to kb-search tool."""
    import subprocess
    vault = find_vault_root()
    search_tool = vault / "tools" / "kb-search"
    if not search_tool.exists():
        err("kb-search not found in tools/ — make sure it's installed")
        sys.exit(1)
    cmd = [sys.executable, str(search_tool), args.query,
           f"--top={args.top}", f"--scope={args.scope}"]
    if getattr(args, 'excerpt', False): cmd.append("--excerpt")
    if getattr(args, 'reindex', False): cmd = [sys.executable, str(search_tool), "--reindex"]
    os.execv(sys.executable, cmd)


