)

def civicgraph_available() -> bool:
    return Path(CIVICGRAPH_TOOL_SCRIPT).exists()

def run_civicgraph_tool(query_type: str, topic: str = "",
                        entity: str = "", state: str = "",
                        limit: int = 8) -> str:
    """
    Call kb-civicgraph-tool.mjs and return JSON string.
    Requires SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY in environment.
    """
    import subprocess
    script = Path(CIVICGRAPH_TOOL_SCRIPT)
    if not script.exists():
        return json.dumps({"error": f"CivicGraph tool not found at {CIVICGRAPH_TOOL_SCRIPT}"})

    # Find the grantscope .env file
    env_file = script.parent.parent / ".env"
    cmd = ["node"]
    if env_file.exists():
        cmd += [f"--env-file={env_file}"]
    cmd += [
        str(script),
        f"--query-type={query_type}",
        f"--limit={limit}",
    ]
    if topic:  cmd.append(f"--topic={topic}")
    if entity: cmd.append(f"--entity={entity}")
    if state:  cmd.append(f"--state={state}")

    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
        if result.stderr:
            return json.dumps({"error": result.stderr[:300]})
        return json.dumps({"error": "No output from CivicGraph tool"})
    except subprocess.TimeoutExpired:
        return json.dumps({"error": "CivicGraph query timed out (30s)"})
    except FileNotFoundError:
        return json.dumps({"error": "node not found — is Node.js installed?"})


