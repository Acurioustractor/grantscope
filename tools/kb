def run_tool(tool_name: str, tool_args: dict, vault: Path) -> str:
    """Execute a tool call and return the result as a string."""

    if tool_name == "search":
        query  = tool_args.get("query", "")
        scope  = tool_args.get("scope", "wiki")
        top_k  = min(int(tool_args.get("top_k", 8)), 20)

        search_tool = vault / "tools" / "kb-search"
        if not search_tool.exists():
            return json.dumps({"error": "Search tool not found. Run: kb search --reindex"})

        import subprocess
        try:
            proc = subprocess.run(
                [sys.executable, str(search_tool), query,
                 f"--top={top_k}", f"--scope={scope}", "--json"],
                capture_output=True, text=True, timeout=15, cwd=str(vault)
            )
            if proc.returncode == 0 and proc.stdout.strip():
                results = json.loads(proc.stdout)
                # Return compact form — just enough for the LLM to decide what to read
                compact = []
                for r in results:
                    compact.append({
                        "path":    r["path"],
                        "title":   r["title"],
                        "summary": r["summary"][:150] if r.get("summary") else "",
                        "score":   r["score"],
                        "bm25":    r.get("bm25", 0),
                        "semantic": r.get("semantic", 0),
                    })
                return json.dumps({"results": compact, "count": len(compact)})
            return json.dumps({"results": [], "count": 0})
        except Exception as e:
            return json.dumps({"error": str(e)})

    elif tool_name == "read_article":
        path_str = tool_args.get("path", "")
        # Try exact path first, then with wiki/ prefix
        for candidate in [vault / path_str, vault / "wiki" / path_str, vault / "raw" / path_str]:
            if candidate.exists() and candidate.suffix == ".md":
                content = read_file(candidate)
                return json.dumps({
                    "path": path_str,
                    "content": truncate(content, 12000),  # single article fits easily
                    "words": word_count(content)
                })
        return json.dumps({"error": f"Article not found: {path_str}"})

    elif tool_name == "civicgraph_query":
        return run_civicgraph_tool(
            query_type = tool_args.get("query_type", "foundations"),
            topic      = tool_args.get("topic", ""),
            entity     = tool_args.get("entity", ""),
            state      = tool_args.get("state", ""),
            limit      = min(int(tool_args.get("limit", 8)), 20),
        )

    return json.dumps({"error": f"Unknown tool: {tool_name}"})


def llm_tool_call(messages: list, tools: list,
                  temperature: float = 0.2, max_tokens: int = 2048) -> dict:
    """
    Single chat completion call with tools. Returns the raw response dict.
    Handles both tool_calls responses and plain text responses.
    """
    payload = json.dumps({
        "model": MODEL,
        "messages": messages,
        "tools": tools,
        "tool_choice": "auto",
        "temperature": temperature,
        "max_tokens": max_tokens,
        "stream": False,
    }).encode()

    req = urllib.request.Request(
        API_URL, data=payload,
        headers={"Content-Type": "application/json"}
    )
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError:
        err(f"Cannot reach LLM at {API_URL}")
        err("Start llama-server with: llama-server -m <model> --jinja -fa -c 131072")
        sys.exit(1)


def search_vault(vault: Path, query: str, top_k: int = 15, scope: str = 'all') -> list:
    """
    Direct search call (used as fallback, not via tool loop).
    Returns list of {path, title, summary, score} dicts.
    """
    import subprocess
    search_tool = vault / "tools" / "kb-search"
    if not search_tool.exists():
        return []
    try:
        result = subprocess.run(
            [sys.executable, str(search_tool), query,
             f"--top={top_k}", f"--scope={scope}", "--json"],
            capture_output=True, text=True, timeout=15, cwd=str(vault)
        )
        if result.returncode == 0 and result.stdout.strip():
            return json.loads(result.stdout)
    except Exception:
        pass
    return []


def maybe_file_to_wiki(vault: Path, question: str, answer: str,
                        agents: str) -> str | None:
    """
    Ask the LLM whether this query answer is wiki-worthy.
    If yes, convert it into a proper wiki article with frontmatter,
    backlinks, and index entry, then file it to wiki/connections/ or
    the most appropriate category.

    Returns the relative path of the filed article, or None if not filed.
    """
    # Don't file very short answers
    if word_count(answer) < 80:
        return None

    # Step 1: quick yes/no — is this worth filing?
    judge_system = """You are deciding whether a query answer should be permanently
filed into a personal knowledge base wiki. Respond with JSON only."""

    judge_prompt = f"""Question asked: {question}

Answer length: {word_count(answer)} words
Answer preview: {answer[:400]}

Should this answer be filed as a permanent wiki article?
File it if the answer:
- Synthesises multiple concepts into a new insight not already in the wiki
- Provides a comparison, analysis, or connection that would be useful to revisit
- Contains specific data, figures, or evidence worth preserving
- Represents a meaningful research finding

Don't file it if the answer is:
- A simple factual lookup (who is X, what is Y)
- A status check or housekeeping query
- Too short or conversational to stand as an article

Return JSON: {{"file": true/false, "reason": "one sentence", "suggested_title": "...", "category": "concept|entity|connection"}}"""

    response = llm_chat(judge_system, judge_prompt, temperature=0.1, max_tokens=256)

    try:
        match = re.search(r'\{.*\}', response, re.DOTALL)
        decision = json.loads(match.group()) if match else {}
    except (json.JSONDecodeError, AttributeError):
        return None

    if not decision.get('file'):
        return None

    # Step 2: convert the answer into a proper wiki article
    title = decision.get('suggested_title', question[:60])
    category = decision.get('category', 'connection')
    reason = decision.get('reason', '')
    slug = re.sub(r'[^a-z0-9]+', '-', title.lower())[:60].strip('-')
    rel_path = f"wiki/{category}s/{slug}.md"
    dest = vault / rel_path

    # Don't overwrite existing articles
    if dest.exists():
        info(f"Not filing — article already exists: {rel_path}")
        return None

    info(f"Filing answer to wiki: {rel_path}")
    info(f"Reason: {reason}")

    # Step 3: ask LLM to format as a proper wiki article
    format_system = f"""{agents}

You are converting a query answer into a wiki article.
Follow the article template from AGENTS.md exactly.
Return ONLY the article content — no commentary, no fences."""

    format_prompt = f"""Convert this query answer into a wiki article.

Original question: {question}
Title: {title}
Category: {category}

Answer to convert:
{answer}

Requirements:
- Include full YAML frontmatter with title, category, created, sources (query), tags, summary
- Use [[wikilinks]] for all cross-references to other wiki articles
- Keep the key insights but structure as an encyclopedic article, not a Q&A
- Add a ## Backlinks section at the bottom (leave empty — will be filled by compile)
- Add a note at the top: > *Filed from query on {now_str()}*
"""

    article = llm_chat(format_system, format_prompt, temperature=0.2, max_tokens=4096)

    if not article.strip():
        return None

    # Write the article
    write_file(dest, article)
    ok(f"Filed to {rel_path}")

    # Step 4: update _index.md to include the new article
    index_path = vault / "wiki" / "_index.md"
    if index_path.exists():
        index_content = read_file(index_path)
        # Extract summary from frontmatter if present
        summary_match = re.search(r'summary:\s*["\']?(.+?)["\']?\s*$',
                                   article, re.MULTILINE)
        summary = summary_match.group(1).strip()[:100] if summary_match else f"Filed from query: {question[:60]}"
        new_row = f"| {rel_path} | {title} | {category} | {now_str()} | {summary} |"

        if "| File | Title | Category |" in index_content:
            lines = index_content.split("\n")
            insert_idx = None
            in_wiki = False
            for i, line in enumerate(lines):
                if "| File | Title | Category |" in line:
                    in_wiki = True
                    continue
                if in_wiki and line.startswith("|---"):
                    insert_idx = i + 1
                    break
            if insert_idx:
                lines.insert(insert_idx, new_row)
                index_content = "\n".join(lines)
                write_file(index_path, index_content)

    return rel_path


def cmd_query(args):
    """Agentic query: LLM calls search() and read_article() as tools, then synthesises."""
    vault = find_vault_root()
    question = args.question
    max_turns = getattr(args, 'turns', 6)   # max tool-call rounds before forcing answer

    heading(f"Query: {question}")

    agents    = get_agents_md(vault)
    wiki_files = list_wiki_files(vault)

    if not wiki_files:
        warn("Wiki is empty — compile some articles first with: kb compile")
        return

    search_tool = vault / "tools" / "kb-search"
    has_search  = search_tool.exists()

    # Auto-reindex in background so embeddings stay fresh
    if has_search:
        import subprocess as _sp
        _sp.Popen([sys.executable, str(search_tool), '--reindex'],
                  stdout=_sp.DEVNULL, stderr=_sp.DEVNULL, cwd=str(vault))

    # Check CivicGraph availability before system prompt uses it
    has_civicgraph = civicgraph_available()
    if has_civicgraph:
        info("CivicGraph live DB connected")

    # ── System prompt ────────────────────────────────────────────────────────
    cg_tool_desc = """
- civicgraph_query(query_type, topic) — query the LIVE CivicGraph database:
    - "foundations" — foundations actively funding a topic
    - "contracts"   — government contracts awarded in a sector
    - "donor_contractors" — entities that donated politically AND hold contracts
    - "grants"      — open grant opportunities
    - "entity"      — full profile of a named organisation
    - "justice_funding" — justice sector funding (ROGS, state YJ programs)
    - "board_interlocks" — shared board members across organisations
  Use CivicGraph to get LIVE data to support or extend what the wiki says.
  Always include CivicGraph results when the question involves money, who funds what,
  specific organisations, or government contracts."""\
  if has_civicgraph else ""

    system_content = f"""{agents}

You are a research agent with access to two data sources:
1. A personal knowledge base wiki (compiled articles on social impact, philanthropy, community power in Australia)
2. CivicGraph — a live database of 587K Australian entities, $1.2T in tracked contracts/donations/grants

Answer questions by:
  1. Calling search() to find relevant wiki articles (use 2-4 different queries)
  2. Calling read_article() to load the most relevant articles in full
  3. Calling civicgraph_query() to pull live data from the database
  4. Synthesising a complete answer that combines wiki knowledge with live CivicGraph data

Available tools:{cg_tool_desc}
- search(query, scope) — hybrid semantic+BM25 search over the wiki
- read_article(path)   — load a full article into context

RULES:
- Always search BEFORE answering — never guess from memory
- For questions about who funds what, always call civicgraph_query()
- Cite wiki articles with [[wikilinks]] and CivicGraph data with entity names + ABNs
- Quote specific figures (dollar amounts, dates, percentages) from your sources
- If neither wiki nor CivicGraph has enough, say so explicitly
- Be concise in synthesis — lead with the key finding, then support with evidence"""

    messages = [
        {"role": "system",  "content": system_content},
        {"role": "user",    "content": f"Question: {question}"}
    ]

    # ── Agentic tool-call loop ────────────────────────────────────────────────
    tools_to_use = list(KB_TOOLS) if has_search else []
    if has_civicgraph:
        tools_to_use.append(CIVICGRAPH_TOOL_DEF)
    turn = 0
    tool_calls_made = []
    articles_loaded = set()
    total_context_chars = 0
    CONTEXT_BUDGET = MAX_CONTEXT_CHARS - len(system_content) - 4000  # reserve for answer

    info(f"Starting agentic search loop (max {max_turns} turns)...")

    while turn < max_turns:
        turn += 1

        # If we've used up context budget, force a final answer
        if total_context_chars > CONTEXT_BUDGET:
            info(f"Context budget reached ({total_context_chars:,} chars) — synthesising...")
            messages.append({
                "role": "user",
                "content": "You have enough context now. Please synthesise a complete answer to the original question, citing the articles you read with [[wikilinks]]."
            })
            tools_to_use = []   # disable tools for final synthesis

        response = llm_tool_call(messages, tools_to_use, temperature=0.2, max_tokens=3000)
        choice   = response.get("choices", [{}])[0]
        message  = choice.get("message", {})
        finish   = choice.get("finish_reason", "stop")

        # ── Case 1: LLM wants to call tools ───────────────────────────────────
        if finish == "tool_calls" and message.get("tool_calls"):
            # Add assistant message with tool_calls to history
            messages.append({
                "role": "assistant",
                "content": message.get("content") or "",
                "tool_calls": message["tool_calls"]
            })

            # Execute each tool call and append results
            for tc in message["tool_calls"]:
                fn_name = tc["function"]["name"]
                try:
                    fn_args = json.loads(tc["function"]["arguments"])
                except json.JSONDecodeError:
                    fn_args = {}

                tool_calls_made.append(fn_name)

                # Show what the agent is doing
                if fn_name == "search":
                    q = fn_args.get("query", "?")
                    scope = fn_args.get("scope", "wiki")
                    print(f"  {C.CYAN}→ search({C.BOLD}{q!r}{C.RESET}{C.CYAN}, scope={scope}){C.RESET}")
                elif fn_name == "read_article":
                    p = fn_args.get("path", "?")
                    articles_loaded.add(p)
                    print(f"  {C.BLUE}→ read_article({C.BOLD}{p}{C.RESET}{C.BLUE}){C.RESET}")
                elif fn_name == "civicgraph_query":
                    qt  = fn_args.get("query_type", "?")
                    top = fn_args.get("topic") or fn_args.get("entity", "?")
                    print(f"  {C.GREEN}→ civicgraph_query({C.BOLD}{qt}{C.RESET}{C.GREEN}, topic={top!r}){C.RESET}")

                result_str = run_tool(fn_name, fn_args, vault)
                total_context_chars += len(result_str)

                messages.append({
                    "role": "tool",
                    "tool_call_id": tc["id"],
                    "content": result_str
                })

            continue   # next turn

        # ── Case 2: LLM produced a text answer (stop / no more tools) ─────────
        answer_text = message.get("content") or ""

        if not answer_text.strip():
            # Empty response — nudge for an answer
            if turn < max_turns:
                messages.append({
                    "role": "user",
                    "content": "Please provide your final answer now, citing the articles you found."
                })
                continue
            break

        # We have a final answer
        break

    # ── Fallback: if loop ended without a text answer, do a direct call ────────
    else:
        # max_turns exhausted — force answer from what we have
        messages.append({
            "role": "user",
            "content": "Summarise what you found and answer the original question as best you can."
        })
        resp = llm_tool_call(messages, [], temperature=0.3, max_tokens=4096)
        answer_text = resp.get("choices", [{}])[0].get("message", {}).get("content", "")

    # ── Print stats then stream the answer ────────────────────────────────────
    searches_done  = tool_calls_made.count("search")
    reads_done     = tool_calls_made.count("read_article")
    cg_done        = tool_calls_made.count("civicgraph_query")
    cg_str         = f", {cg_done} CivicGraph DB query(ies)" if cg_done else ""
    info(f"Agent used {searches_done} search(es), read {reads_done} article(s)"
         f"{cg_str} across {turn} turn(s)")
    if articles_loaded:
        for p in sorted(articles_loaded):
            print(f"  {C.DIM}  read: {p}{C.RESET}")

    print(f"\n{C.DIM}{'─' * 60}{C.RESET}")

    # If no tool support (search not available), fall back to direct retrieval
    if not has_search and not answer_text:
        # Classic path: load top articles directly
        raw_results = search_vault(vault, question, top_k=10, scope='wiki')
        selected_paths = [r['path'] for r in raw_results] if raw_results else \
                         [str(f.relative_to(vault)) for f in wiki_files[:8]]
        context_parts = []
        for p in selected_paths:
            fpath = vault / p
            if not fpath.exists():
                fpath = vault / "wiki" / p
            if fpath.exists():
                context_parts.append(f"--- {p} ---\n{read_file(fpath)}")
        wiki_context = truncate("\n\n".join(context_parts))
        direct_system = f"""{agents}\nAnswer using the wiki articles below. Cite with [[wikilinks]]."""
        answer_text = llm_stream(direct_system,
                                 f"Question: {question}\n\nWiki:\n{wiki_context}",
                                 temperature=0.3, max_tokens=4096)
    else:
        # Stream the answer we already have
        for char in answer_text:
            print(char, end='', flush=True)
        print()

    print(f"{C.DIM}{'─' * 60}{C.RESET}")

    # ── Log the query ─────────────────────────────────────────────────────
    append_log(vault, "query", question,
               f"searches: {searches_done}, articles read: {reads_done}"
               + (f", civicgraph queries: {cg_done}" if cg_done else ""))

    # ── Auto-file: ask LLM whether this answer belongs in the wiki ──────────
    # This closes the compounding loop: explorations add back to the wiki.
    if answer_text and not getattr(args, 'no_file', False):
        filed_path = maybe_file_to_wiki(vault, question, answer_text, agents)
        if filed_path:
            append_log(vault, "filed", question,
                       f"path: {filed_path}\n"
                       f"reason: query answer judged wiki-worthy and filed")

    # ── Save if explicitly requested ─────────────────────────────────────
    if args.save or args.slides:
        if args.slides:
            # Re-ask for Marp format
            info("Converting to Marp slides...")
            slide_system = f"{agents}\n\nConvert the following answer into a Marp slide deck. Use the Marp format from AGENTS.md."
            slide_prompt = f"Convert this into a Marp slide deck:\n\n{answer_text}"
            slides = llm_chat(slide_system, slide_prompt, max_tokens=4096)

            slug = re.sub(r'[^a-z0-9]+', '-', question.lower())[:50].strip("-")
            dest = vault / "outputs" / "slides" / f"{slug}.md"
            write_file(dest, slides)
            ok(f"Saved slides to outputs/slides/{slug}.md")
            append_log(vault, "output", f"slides: {slug}.md", f"question: {question}")
        else:
            slug = re.sub(r'[^a-z0-9]+', '-', question.lower())[:50].strip("-")
            dest = vault / "outputs" / "reports" / f"{slug}.md"
            header = f"---\ntitle: \"{question}\"\ndate: {now_str()}\ntype: query-report\n---\n\n# {question}\n\n"
            write_file(dest, header + answer_text)
            ok(f"Saved report to outputs/reports/{slug}.md")
            append_log(vault, "output", f"report: {slug}.md", f"question: {question}")


def cmd_lint(args):
    """Check wiki health and consistency."""
    vault = find_vault_root()

    heading("Linting knowledge base")

    agents = get_agents_md(vault)
    wiki_files = list_wiki_files(vault)

    if not wiki_files:
        warn("Wiki is empty — nothing to lint.")
        return

    # Build context
    all_content = ""
    for f in wiki_files:
        rel = f.relative_to(vault / "wiki")
        all_content += f"\n\n--- {rel} ---\n{read_file(f)}"

    index = get_index(vault)
    all_content = truncate(all_content)

    system = f"""{agents}

You are auditing this knowledge base for quality issues."""

    user_prompt = f"""Review all wiki articles below and identify:

1. **Inconsistencies** — conflicting facts, dates, or figures across articles
2. **Missing backlinks** — articles that reference concepts without [[wikilinks]]
3. **Coverage gaps** — important concepts mentioned but lacking dedicated articles
4. **Stale data** — information that may be outdated
5. **Format issues** — articles missing required frontmatter fields
6. **Suggested improvements** — new connections, articles, or edits

Current index:
{truncate(index, 5000)}

Wiki articles:
{all_content}

{"Also suggest specific fixes for each issue." if args.fix else "List issues only."}"""

    print(f"{C.DIM}{'─' * 60}{C.RESET}")
    response = llm_stream(system, user_prompt, temperature=0.3, max_tokens=4096)
    print(f"{C.DIM}{'─' * 60}{C.RESET}")

    append_log(vault, "lint", f"{len(wiki_files)} articles checked",
               f"fix mode: {'yes' if args.fix else 'no'}")

    if args.fix:
        # Ask for fix confirmation
        print(f"\n{C.YELLOW}Auto-fix is experimental.{C.RESET} Review the suggestions above.")
        confirm = input(f"\nApply fixes? [y/N] ").strip().lower()
        if confirm == "y":
            fix_prompt = f"""Based on the issues identified above, output corrected versions of articles that need fixing.

Use the same format:
===FILE: wiki/category/article-name.md===
(corrected content)
===END===

Issues found:
{response}

Current articles:
{all_content}"""

            info("Generating fixes...")
            fix_response = llm_chat(system, fix_prompt, temperature=0.2, max_tokens=8192)

            file_pattern = re.compile(r'===FILE:\s*(.+?)===\s*\n(.*?)===END===', re.DOTALL)
            fixes = 0
            for match in file_pattern.finditer(fix_response):
                filepath = match.group(1).strip()
                content = match.group(2).strip() + "\n"
                dest = vault / filepath
                write_file(dest, content)
                ok(f"Fixed {filepath}")
                fixes += 1

            if fixes:
                ok(f"Applied {fixes} fix(es).")
            else:
                warn("No fixes were generated in the expected format.")
        else:
            info("No fixes applied.")


def cmd_status(args):
    """Show knowledge base stats."""
    vault = find_vault_root()

    heading("Knowledge Base Status")

    raw_files = list_raw_files(vault)
    wiki_files = list_wiki_files(vault)

    raw_words = sum(word_count(read_file(f)) for f in raw_files)
    wiki_words = sum(word_count(read_file(f)) for f in wiki_files)
    total_words = raw_words + wiki_words

    # Count by category
    concepts = [f for f in wiki_files if "concepts" in str(f)]
    entities = [f for f in wiki_files if "entities" in str(f)]
    connections = [f for f in wiki_files if "connections" in str(f)]

    print(f"  {C.BOLD}Vault:{C.RESET}        {vault}")
    print(f"  {C.BOLD}Raw sources:{C.RESET}  {len(raw_files)} ({raw_words:,} words)")
    print(f"  {C.BOLD}Wiki total:{C.RESET}   {len(wiki_files)} articles ({wiki_words:,} words)")
    print(f"    Concepts:    {len(concepts)}")
    print(f"    Entities:    {len(entities)}")
    print(f"    Connections: {len(connections)}")
    print(f"  {C.BOLD}Total words:{C.RESET}  {total_words:,}")

    # Find wikilinks
    all_links = set()
    all_targets = set()
    for f in wiki_files:
        content = read_file(f)
        links = re.findall(r'\[\[([^\]]+)\]\]', content)
        all_links.update(links)
        all_targets.add(f.stem)

    broken = [l for l in all_links if l not in all_targets and not l.startswith("raw/")]
    if broken:
        print(f"\n  {C.YELLOW}Broken links:{C.RESET} {len(broken)}")
        for b in broken[:10]:
            print(f"    → [[{b}]]")

    # Last modified
    if wiki_files:
        newest = max(wiki_files, key=lambda f: f.stat().st_mtime)
        from datetime import datetime as dt
        mtime = dt.fromtimestamp(newest.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
        print(f"\n  {C.BOLD}Last updated:{C.RESET} {mtime} ({newest.name})")

    print()


