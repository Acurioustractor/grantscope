{
  "name": "grantscope",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Australian funding transparency platform",
  "scripts": {
    "dev": "pnpm --filter @grantscope/web dev",
    "build": "pnpm --filter @grantscope/web build",
    "typecheck": "pnpm -r typecheck",
    "preflight": "node --env-file=.env scripts/preflight.mjs",
    "signoff": "node --env-file=.env scripts/grantscope-signoff.mjs",
    "signoff:full": "node --env-file=.env scripts/grantscope-signoff.mjs --full",
    "branch:check": "node scripts/grantscope-signoff.mjs --branch-only",
    "wiki:support:index": "node scripts/build-wiki-support-index.mjs",
    "wiki:support:frontier": "node --env-file=.env scripts/seed-wiki-support-frontier.mjs",
    "report:youth-justice:cache": "node --env-file=.env scripts/refresh-youth-justice-report-cache.mjs",
    "report:youth-justice:snapshot": "node --env-file=.env scripts/build-youth-justice-report-snapshot.mjs",
    "report:youth-justice:refresh": "npm run report:youth-justice:cache && npm run report:youth-justice:snapshot",
    "report:youth-justice:source-refresh": "node --env-file=.env scripts/refresh-youth-justice-source-chain.mjs && node --env-file=.env scripts/run-tracker-refresh.mjs --domain=youth-justice --all-jurisdictions && npm run report:youth-justice:refresh",
    "discover": "tsx scripts/grantscope-discovery.mjs",
    "sync-acnc": "tsx scripts/sync-acnc-register.mjs",
    "funding-benchmark:build": "node scripts/funding-autoresearch/build-benchmark-set.mjs",
    "funding-benchmark:evaluate": "node scripts/funding-autoresearch/evaluate.mjs --save",
    "funding-autoresearch": "node scripts/funding-autoresearch/autoresearch.mjs",
    "bittensor:money-model": "node scripts/bittensor-money-model.mjs",
    "grant:frontier:snapshot": "node --env-file=.env scripts/snapshot-grant-frontier.mjs",
    "grant:long-tail:discover": "node --env-file=.env scripts/discover-foundation-programs.mjs --refresh-existing --rescan-days=14 --limit=20 --concurrency=1 --frontier-metadata-flag=long_tail_priority --agent-id=discover-foundation-programs-long-tail --agent-name=\"Discover Foundation Programs Long Tail\"",
    "tracker:evidence:sync": "node --env-file=.env scripts/sync-tracker-evidence.mjs",
    "tracker:source-chain": "node --env-file=.env scripts/refresh-youth-justice-source-chain.mjs",
    "tracker:refresh": "node --env-file=.env scripts/run-tracker-refresh.mjs",
    "tracker:refresh:qld": "node --env-file=.env scripts/run-tracker-refresh.mjs --domain=youth-justice --jurisdiction=QLD",
    "tracker:refresh:nsw": "node --env-file=.env scripts/run-tracker-refresh.mjs --domain=youth-justice --jurisdiction=NSW",
    "tracker:refresh:nt": "node --env-file=.env scripts/run-tracker-refresh.mjs --domain=youth-justice --jurisdiction=NT",
    "tracker:refresh:portfolio": "node --env-file=.env scripts/run-tracker-refresh.mjs --domain=youth-justice --all-jurisdictions"
  },
  "keywords": [
    "grants",
    "australia",
    "philanthropy",
    "transparency",
    "open-data"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.6.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "author": "A Curious Tractor",
  "packageManager": "pnpm@10.12.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Acurioustractor/grantscope.git"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0"
  }
}
